{
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "hosting": {
    "public": "web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/finishSignIn",
        "destination": "/finishSignIn.html"
      },
      {
        "source": "/join",
        "destination": "/join.html"
      }
    ]
  }
}